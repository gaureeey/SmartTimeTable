<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
    version="5.0">

    <display-name>Smart Timetable Generator</display-name>

    <context-param>
        <param-name>deleteMode</param-name>
        <param-value>soft</param-value>
    </context-param>

    <context-param>
        <param-name>ollamaApiUrl</param-name>
        <param-value>http://127.0.0.1:11434/api/generate</param-value>
    </context-param>

    <context-param>
        <param-name>ollamaModel</param-name>
        <param-value>qwen2.5-coder:7b</param-value>
    </context-param>

    <session-config>
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
        </cookie-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.timetable.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SignupServlet</servlet-name>
        <servlet-class>com.timetable.controller.SignupServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SignupServlet</servlet-name>
        <url-pattern>/signup</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.timetable.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.timetable.controller.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AddEntryServlet</servlet-name>
        <servlet-class>com.timetable.controller.AddEntryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddEntryServlet</servlet-name>
        <url-pattern>/add-entry</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ViewEntriesServlet</servlet-name>
        <servlet-class>com.timetable.controller.ViewEntriesServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewEntriesServlet</servlet-name>
        <url-pattern>/view-entries</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EditEntryServlet</servlet-name>
        <servlet-class>com.timetable.controller.EditEntryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditEntryServlet</servlet-name>
        <url-pattern>/edit-entry</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UpdateEntryServlet</servlet-name>
        <servlet-class>com.timetable.controller.UpdateEntryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateEntryServlet</servlet-name>
        <url-pattern>/update-entry</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteEntryServlet</servlet-name>
        <servlet-class>com.timetable.controller.DeleteEntryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteEntryServlet</servlet-name>
        <url-pattern>/delete-entry</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AutoGenerateServlet</servlet-name>
        <servlet-class>com.timetable.controller.AutoGenerateServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AutoGenerateServlet</servlet-name>
        <url-pattern>/auto-generate</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>TimetableGridServlet</servlet-name>
        <servlet-class>com.timetable.controller.TimetableGridServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TimetableGridServlet</servlet-name>
        <url-pattern>/timetable-grid</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

    <error-page>
        <error-code>404</error-code>
        <location>/errors/404.jsp</location>
    </error-page>

    <error-page>
        <error-code>500</error-code>
        <location>/errors/500.jsp</location>
    </error-page>

    <error-page>
        <exception-type>java.lang.Exception</exception-type>
        <location>/error.jsp</location>
    </error-page>
</web-app>
